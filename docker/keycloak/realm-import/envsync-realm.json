{
  "realm": "envsync",
  "enabled": true,
  "displayName": "EnvSync",
  "sslRequired": "NONE",
  "loginTheme": "envsync",
  "emailTheme": "envsync",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 604800,
  "ssoSessionMaxLifespan": 604800,
  "clientSessionIdleTimeout": 604800,
  "clientSessionMaxLifespan": 604800,
  "clients": [
    {
      "clientId": "envsync-web",
      "name": "EnvSync Web",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "secret": "test-web-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://app.lvh.me:8001",
        "http://app.lvh.me:8001/auth/callback",
        "http://api.lvh.me:4000/api/access/web/callback",
        "http://localhost:8001",
        "http://localhost:8001/auth/callback",
        "http://localhost:4000/api/access/web/callback"
      ],
      "webOrigins": [
        "http://app.lvh.me:8001",
        "http://localhost:8001"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      },
      "defaultClientScopes": [
        "basic",
        "web-origins",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "envsync-api",
      "name": "EnvSync API",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": false,
      "secret": "test-api-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://api.lvh.me:4000/api/access/api/callback",
        "http://localhost:4000/api/access/api/callback"
      ],
      "webOrigins": [
        "http://api.lvh.me:4000",
        "http://localhost:4000"
      ],
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "envsync-cli",
      "name": "EnvSync CLI",
      "protocol": "openid-connect",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true"
      },
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles"
      ]
    }
  ]
}
