{
  "name": "@envsync-cloud/envsync-management-ts-sdk",
  "description": "TypeScript SDK for the EnvSync Management API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --watch --config tsup.config.ts",
    "check:pack": "npm pack --dry-run",
    "openapi": "openapi",
    "generate": "bun run generate:local && bun run build",
    "generate:local": "bun run scripts/gen.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "openapi-typescript-codegen": "^0.29.0",
    "tsup": "^8.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "version": "0.8.7",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EnvSync-Cloud/envsync.git",
    "directory": "sdks/envsync-management-ts-sdk"
  },
  "homepage": "https://github.com/EnvSync-Cloud/envsync/tree/main/sdks/envsync-management-ts-sdk#readme",
  "bugs": {
    "url": "https://github.com/EnvSync-Cloud/envsync/issues"
  },
  "author": "EnvSync Cloud",
  "license": "MIT",
  "keywords": [
    "envsync",
    "sdk",
    "typescript",
    "openapi",
    "management-api-client"
  ],
  "publishConfig": {
    "access": "public"
  }
}
